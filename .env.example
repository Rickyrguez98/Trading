# Copy to `.env` and fill in any keys you have.
# All providers default to free/keyless sources. Keys below are OPTIONAL and
# unlock alternative providers that you can wire up later.

# --- Optional: financial data providers ---
# Free tier exists for each of these. None are required to run the default pipeline.
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=

# --- Optional: news providers ---
NEWSAPI_API_KEY=
MARKETAUX_API_KEY=

# --- Runtime / logging ---
ASSET_SELECTION_LOG_LEVEL=INFO
ASSET_SELECTION_CACHE_DIR=data/cache
